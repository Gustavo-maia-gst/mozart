{
  "title": "Mozart Scenario",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        }
      ]
    },
    "protocol": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "anyOf": [
        {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "id"
            ]
          }
        },
        {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      ]
    },
    "graphs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "tasks": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "dependsOn": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "costMs": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "id"
              ]
            }
          },
          "startAfterMs": {
            "default": 0,
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "id",
          "tasks"
        ]
      }
    },
    "storage": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "adapter": {
              "type": "string",
              "const": "in-memory"
            }
          },
          "required": [
            "adapter"
          ]
        },
        {
          "type": "object",
          "properties": {
            "adapter": {
              "type": "string",
              "const": "postgres"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "adapter"
          ]
        }
      ]
    },
    "transport": {
      "default": {
        "ackTimeoutMs": 2000
      },
      "type": "object",
      "properties": {
        "ackTimeoutMs": {
          "default": 2000,
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "latency": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "distribution": {
                "type": "string",
                "const": "constant"
              },
              "value": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "distribution",
              "value"
            ]
          },
          {
            "type": "object",
            "properties": {
              "distribution": {
                "type": "string",
                "const": "normal"
              },
              "mean": {
                "type": "number"
              },
              "stddev": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "distribution",
              "mean",
              "stddev"
            ]
          },
          {
            "type": "object",
            "properties": {
              "distribution": {
                "type": "string",
                "const": "lognormal"
              },
              "mu": {
                "type": "number"
              },
              "sigma": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "distribution",
              "mu",
              "sigma"
            ]
          },
          {
            "type": "object",
            "properties": {
              "distribution": {
                "type": "string",
                "const": "uniform"
              },
              "min": {
                "type": "number",
                "minimum": 0
              },
              "max": {
                "type": "number",
                "minimum": 0
              }
            },
            "required": [
              "distribution",
              "min",
              "max"
            ]
          }
        ]
      }
    },
    "faults": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "const": "killNode"
                  },
                  "at": {
                    "type": "number",
                    "minimum": 0
                  },
                  "node": {
                    "type": "string",
                    "minLength": 1
                  },
                  "restartAfterMs": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "action",
                  "at",
                  "node"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "const": "storageOutage"
                  },
                  "at": {
                    "type": "number",
                    "minimum": 0
                  },
                  "scope": {
                    "anyOf": [
                      {
                        "type": "string",
                        "const": "all"
                      },
                      {
                        "type": "string",
                        "minLength": 1
                      }
                    ]
                  },
                  "durationMs": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  }
                },
                "required": [
                  "action",
                  "at",
                  "scope",
                  "durationMs"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "const": "partitionNode"
                  },
                  "at": {
                    "type": "number",
                    "minimum": 0
                  },
                  "node": {
                    "type": "string",
                    "minLength": 1
                  },
                  "durationMs": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "direction": {
                    "default": "both",
                    "type": "string",
                    "enum": [
                      "in",
                      "out",
                      "both"
                    ]
                  }
                },
                "required": [
                  "action",
                  "at",
                  "node",
                  "durationMs"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "const": "duplicateDeliveries"
                  },
                  "at": {
                    "type": "number",
                    "minimum": 0
                  },
                  "extraCopies": {
                    "default": 1,
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "action",
                  "at"
                ]
              },
              {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "const": "failTask"
                  },
                  "taskId": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "action",
                  "taskId"
                ]
              }
            ]
          },
          {
            "type": "object",
            "properties": {
              "restartAfterMs": {
                "default": 500,
                "type": "number",
                "exclusiveMinimum": 0
              },
              "times": {
                "default": 1,
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "additionalProperties": {
              "type": "string"
            }
          }
        ]
      }
    },
    "endCondition": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "timeout"
            },
            "ms": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "type",
            "ms"
          ]
        }
      ]
    }
  },
  "required": [
    "name",
    "seed",
    "protocol",
    "nodes",
    "graphs",
    "storage",
    "endCondition"
  ]
}
