{
  "name": "mozart",
  "version": "0.1.0",
  "private": true,
  "description": "Test harness for distributed DAG-coordination protocols",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --dry",
    "test": "vitest run",
    "test:integration": "MOZART_INTEGRATION=1 vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --fix --unsafe",
    "demo": "pnpm build && node apps/master/dist/main.js --scenario scenarios/baseline.yaml",
    "traces:clean": "docker compose restart jaeger"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@eslint/js": "^9.39.0",
    "@swc/core": "^1.13.0",
    "@types/node": "^22.19.0",
    "eslint": "^9.39.0",
    "prettier": "^3.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.2.0"
  }
}
