{
  "name": "mozart",
  "version": "0.1.0",
  "private": true,
  "description": "Test harness for distributed DAG-coordination protocols",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b --dry",
    "test": "vitest run",
    "test:integration": "MOZART_INTEGRATION=1 vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --fix --unsafe",
    "demo": "pnpm build && pnpm start --scenario scenarios/baseline.yaml",
    "scenario:from-csv": "tsx scripts/csv-to-scenario.ts",
    "schema:gen": "tsx scripts/gen-scenario-schema.ts",
    "start": "node apps/master/dist/main.js",
    "telemetry:clean": "docker compose stop jaeger prometheus grafana; docker compose rm -f jaeger prometheus grafana; docker volume rm mozart_prometheus_data mozart_grafana_data; docker compose up -d jaeger prometheus grafana"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@eslint/js": "^9.39.0",
    "@swc/core": "^1.13.0",
    "@types/node": "^22.19.0",
    "eslint": "^9.39.0",
    "graphology-types": "^0.24.8",
    "prettier": "^3.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "unplugin-swc": "^1.5.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "graphology": "^0.26.0"
  }
}
