{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/*.spec.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "bracketSpacing": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnsafeOptionalChaining": "off",
        "noUnusedPrivateClassMembers": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off",
        "noImplicitAnyLet": "off",
        "noConfusingVoidType": "off"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 14
          }
        },
        "useSimplifiedLogicExpression": "off",
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 45,
            "skipBlankLines": true,
            "skipIifes": false
          }
        },
        "noStaticOnlyClass": "off",
        "useMaxParams": {
          "level": "error",
          "options": {
            "max": 5
          }
        }
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "off"
      }
    }
  }
}
