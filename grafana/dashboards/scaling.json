          "options": {
            "fields": {},
            "sort": [
              {
                "field": "mozart_nodes",
                "desc": false
              }
            ]
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "(sum by (mozart_nodes, mozart_protocol) (histogram_sum(last_over_time(mozart_dag_makespan_milliseconds{mozart_scenario=~\"$scenario\", mozart_protocol=~\"$protocol\"}[$__range]))) / sum by (mozart_nodes, mozart_protocol) (histogram_count(last_over_time(mozart_dag_makespan_milliseconds{mozart_scenario=~\"$scenario\", mozart_protocol=~\"$protocol\"}[$__range])))) - (sum by (mozart_nodes, mozart_protocol) (histogram_sum(last_over_time(mozart_dag_critical_path_milliseconds{mozart_scenario=~\"$scenario\", mozart_protocol=~\"$protocol\"}[$__range]))) / sum by (mozart_nodes, mozart_protocol) (histogram_count(last_over_time(mozart_dag_critical_path_milliseconds{mozart_scenario=~\"$scenario\", mozart_protocol=~\"$protocol\"}[$__range]))))",
          "legendFormat": "__auto"
        }
      ]
    },
